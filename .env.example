# ─── GiftVibes Ultimate — Environment Variables ──────────────────────────
# Copy this to .env and fill in your values

# ─── Supabase (shared by both apps) ────────────────────────────────────
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_PUBLISHABLE_KEY=eyJ...

# ─── Admin Panel (apps/admin) ──────────────────────────────────────────
# The admin uses SUPABASE_URL, SUPABASE_ANON_KEY, SUPABASE_SERVICE_ROLE_KEY above
# Cloudflare Workers deployment:
# CF_ACCOUNT_ID=
# CF_API_TOKEN=

# ─── Storefront (apps/storefront) ──────────────────────────────────────
NEXT_PUBLIC_ADMIN_API_URL=http://localhost:5174
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Direct database connection (for Prisma)
DATABASE_URL=postgresql://postgres:password@localhost:54322/postgres

# Email (enquiry notifications)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_TO=info@giftvibes.in

# ─── On-demand revalidation (admin → storefront webhook) ───────────────
# Set the SAME random string in both apps.
# Storefront (Vercel):    REVALIDATE_SECRET=<random>
# Admin (Cloudflare):     STOREFRONT_REVALIDATE_URL=https://www.giftvibes.in/api/revalidate
#                         STOREFRONT_REVALIDATE_SECRET=<same random>
REVALIDATE_SECRET=
STOREFRONT_REVALIDATE_URL=
STOREFRONT_REVALIDATE_SECRET=